// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id             String     @id @default(cuid())
  nombre         String     @unique
  precioPorLibra Decimal    @db.Decimal(10, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  purchases      Purchase[]
}

model DailyBalance {
  id           String   @id @default(cuid())
  businessDate DateTime @db.Date @unique
  saldoInicial Decimal  @db.Decimal(12, 2)
  saldoActual  Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Purchase {
  id             String   @id @default(cuid())
  businessDate   DateTime @db.Date
  materialId     String
  materialNombre String
  precioPorLibra Decimal  @db.Decimal(10, 2)
  libras         Decimal  @db.Decimal(10, 2)
  total          Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  material       Material @relation(fields: [materialId], references: [id], onDelete: Restrict)

  @@index([businessDate])
}

model Sale {
  id           String   @id @default(cuid())
  businessDate DateTime @db.Date
  descripcion  String
  monto        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  @@index([businessDate])
}

model Expense {
  id           String   @id @default(cuid())
  businessDate DateTime @db.Date
  categoria    String
  descripcion  String
  monto        Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  @@index([businessDate])
}

model SyncEvent {
  id        String   @id @default(cuid())
  source    String
  entity    String
  entityId  String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
